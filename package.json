    "@dfinity/principal": "^0.12.1",
    "assert": "2.0.0",
    "buffer": "6.0.3",
    "copy-webpack-plugin": "^10.1.0",
    "css-loader": "^6.7.1",
    "customize-cra": "latest",
    "events": "3.3.0",
    "html-webpack-plugin": "5.5.0",
    "process": "0.11.10",
    "react-app-rewired": "latest",
    "remove-console-webpack-plugin": "^0.2.0",
    "stream-browserify": "3.0.0",
    "style-loader": "^3.3.1",
    "svgo": "^2.8.0",
    "terser-webpack-plugin": "5.2.5",
    "ts-loader": "^9.2.6",
    "typescript": "^4.7.4",
    "util": "0.12.4",
    "webpack": "^5.73.0",
    "webpack-cli": "~4.9.1",
    "webpack-dev-server": "^4.6.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
